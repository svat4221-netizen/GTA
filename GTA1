<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>GTA RP Browser</title>

<style>

body{
margin:0;
overflow:hidden;
}

#chat{
position:absolute;
left:10px;
bottom:10px;
width:300px;
height:150px;
background:rgba(0,0,0,0.5);
color:white;
font-family:arial;
padding:5px;
}

#input{
width:100%;
}

#joystick{
position:absolute;
bottom:40px;
left:40px;
width:120px;
height:120px;
background:rgba(255,255,255,0.2);
border-radius:50%;
}

#stick{
width:60px;
height:60px;
background:white;
border-radius:50%;
position:relative;
top:30px;
left:30px;
}

</style>
</head>

<body>

<div id="chat">
<div id="messages"></div>
<input id="input" placeholder="чат">
</div>

<div id="joystick">
<div id="stick"></div>
</div>

<script src="https://cdn.socket.io/4.5.4/socket.io.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.152.0/build/three.min.js"></script>

<script>

const socket = io("http://localhost:3000");

let scene = new THREE.Scene();

let camera = new THREE.PerspectiveCamera(
75,
window.innerWidth/window.innerHeight,
0.1,
1000
);

let renderer = new THREE.WebGLRenderer();

renderer.setSize(
window.innerWidth,
window.innerHeight
);

document.body.appendChild(renderer.domElement);

let player;

let geometry = new THREE.BoxGeometry(1,2,1);
let material = new THREE.MeshBasicMaterial({color:0x00ff00});

player = new THREE.Mesh(geometry,material);
scene.add(player);

camera.position.z = 5;

let players = {};

socket.on("currentPlayers",(serverPlayers)=>{

for(let id in serverPlayers){

addPlayer(id);

}

});

socket.on("newPlayer",(data)=>{

addPlayer(data);

});

socket.on("playerMoved",(data)=>{

if(players[data.id]){

players[data.id].position.x=data.x;
players[data.id].position.z=data.z;

}

});

function addPlayer(id){

let p = new THREE.Mesh(
new THREE.BoxGeometry(1,2,1),
new THREE.MeshBasicMaterial({color:0xff0000})
);

scene.add(p);

players[id]=p;

}

function animate(){

requestAnimationFrame(animate);

renderer.render(scene,camera);

}

animate();

document.addEventListener("keydown",(e)=>{

if(e.key==="w") player.position.z-=0.1;
if(e.key==="s") player.position.z+=0.1;
if(e.key==="a") player.position.x-=0.1;
if(e.key==="d") player.position.x+=0.1;

socket.emit("move",{
x:player.position.x,
z:player.position.z
});

});

</script>

</body>
